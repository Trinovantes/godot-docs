{
    "type": "module",
    "private": true,
    "scripts": {
        "clean": "rm -rf ./src/.cache.json ./.cache ./src/.vitepress-*.json ./.vitepress/dist",
        "lint": "vue-tsc && eslint",
        "compile": "node --env-file=.env ./src/compileRst.ts",
        "debug": "  node --env-file=.env ./src/VitePressConfig/debugVitepressConfig.ts",
        "index": "  node --env-file=.env ./src/Search/generateSearchIndex.ts",
        "dev": "    node --max-old-space-size=16384 --stack-size=1024 ./node_modules/vitepress/bin/vitepress.js dev --port 8080",
        "build": "  node --max-old-space-size=16384 --stack-size=1024 ./node_modules/vitepress/bin/vitepress.js build",
        "preview": "node --max-old-space-size=16384 --stack-size=1024 ./node_modules/vitepress/bin/vitepress.js preview"
    },
    "devDependencies": {
        "@docsearch/css": "^4.6.0",
        "@eslint/compat": "^2.0.3",
        "@eslint/js": "^10.0.1",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@types/node": "^25.3.5",
        "@vueuse/core": "^14.2.1",
        "algoliasearch": "^5.49.1",
        "eslint": "^10.0.3",
        "eslint-plugin-n": "^17.24.0",
        "eslint-plugin-vue": "^10.8.0",
        "fast-glob": "^3.3.3",
        "globals": "^17.4.0",
        "markdown-it": "^14.1.1",
        "rst-compiler": "^0.5.7",
        "sass": "^1.97.3",
        "shiki": "^4.0.1",
        "source-map-support": "^0.5.21",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1",
        "vite": "^7.3.1",
        "vitepress": "^1.6.4",
        "vitepress-plugin-tabs": "^0.8.0",
        "vue": "^3.5.29",
        "vue-eslint-parser": "^10.4.0",
        "vue-tsc": "^3.2.5"
    }
}
