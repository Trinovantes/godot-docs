{
    "type": "module",
    "private": true,
    "scripts": {
        "clean": "rm -rf ./src/.cache.json ./.cache ./src/.vitepress-*.json ./.vitepress/dist",
        "lint": "vue-tsc && eslint",
        "index": "  node ./src/generateSearchIndex.ts",
        "compile": "node ./src/compileRst.ts",
        "debug": "  node ./src/debugVitepressConfig.ts",
        "dev": "    node --env-file=.env --max-old-space-size=16384 --stack-size=1024 ./node_modules/vitepress/bin/vitepress.js dev --port 8080",
        "build": "  node --env-file=.env --max-old-space-size=16384 --stack-size=1024 ./node_modules/vitepress/bin/vitepress.js build",
        "preview": "node --env-file=.env --max-old-space-size=16384 --stack-size=1024 ./node_modules/vitepress/bin/vitepress.js preview"
    },
    "devDependencies": {
        "@docsearch/css": "^3.9.0",
        "@eslint/compat": "^1.3.2",
        "@eslint/js": "^9.35.0",
        "@stylistic/eslint-plugin": "^5.3.1",
        "@types/node": "^22.18.3",
        "@vueuse/core": "^13.9.0",
        "algoliasearch": "^5.37.0",
        "eslint": "^9.35.0",
        "eslint-plugin-n": "^17.22.0",
        "eslint-plugin-vue": "^10.4.0",
        "fast-glob": "^3.3.3",
        "globals": "^16.4.0",
        "markdown-it": "^14.1.0",
        "rst-compiler": "^0.5.6",
        "sass": "^1.92.1",
        "shiki": "^3.12.2",
        "source-map-support": "^0.5.21",
        "typescript": "^5.9.2",
        "typescript-eslint": "^8.43.0",
        "vite": "^7.1.5",
        "vitepress": "^1.6.4",
        "vitepress-plugin-tabs": "^0.7.2",
        "vue": "^3.5.21",
        "vue-eslint-parser": "^10.2.0",
        "vue-tsc": "^3.0.7"
    }
}
